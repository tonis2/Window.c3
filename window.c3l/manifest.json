{ 
  "provides" : "c3w",
  "targets" : {
    "macos-x64" : {
      "linked-libraries" : ["CoreFoundation.framework", "Cocoa.framework"],
      "c-sources" : ["native/cocoa.m"],
      "cflags": "-c -framework Foundation -framework Cocoa -fPIC"
    },
    "linux-x64" : {
      "cflags": "-fPIE",
      "c-sources" : ["native/xcb.c"],
      "linked-libraries" : ["X11", "Xrandr", "X11-xcb", "xcb"]
    },
    "windows-x64" : {
      "c-sources" : ["native/win32.c"],
      "linked-libraries" : []
    }
  }
}