{ 
  "provides" : "c3w",
  "targets" : {
    "macos-x64" : {
      "exec": ["swiftc -emit-object -parse-as-library window.c3l/window.swift"],
      "linked-libraries" : []
    },
    "linux-x64" : {
      "cflags": "-fPIE",
      "c-sources" : ["xcb.c"],
      "linked-libraries" : ["X11", "Xrandr", "X11-xcb", "xcb"]
    },
    "windows-x64" : {
      "c-sources" : ["win32.c"],
      "linked-libraries" : []
    }
  }
}