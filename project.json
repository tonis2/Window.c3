{
	"langrev": "1",
	"warnings": ["no-unused"],
	"authors": [],
	"version": "0.1.2",
	"script-dir": "./",
	"dependency-search-paths": ["./"],
	"sources": ["darwin/**", "linux/**", "win32/**", "wasm/**", "main.c3"],
	"linked-libraries": [],
	"features": [],
	"targets": {
		"test": {
			"type": "executable",
			"sources": ["./test/main.c3"],
			"features": [],
			"dependencies": []
		},
		"test-win": {
			"type": "executable",
			"sources": ["./test/main.c3"],
			"target": "windows-x64",
			"dependencies": []
		},
		"test-wasm": {
			"type": "executable",
			"sources": ["./test/main_web.c3"],
			"target": "wasm32",
			"link-libc": false,
			"no-entry": true,
			"output": "./test/web"
		},
		"zip": {
			"type": "prepare",
			"exec": ["zip window.c3l ./*.c3 ./darwin/*.c3 ./linux/*.c3 ./win32/*.c3 ./manifest.json"]
		}
	},
	"output": "./build"
}